# Contact form email settings
# Copy this file to .env.local and fill in your SMTP credentials

# Gmail / Google Workspace SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=contact@simpleraai.com
# For Gmail: use an App Password (myaccount.google.com > Security > App passwords)
SMTP_PASS=your-app-password-here

# Email address to receive contact form submissions
CONTACT_EMAIL=contact@simpleraai.com
